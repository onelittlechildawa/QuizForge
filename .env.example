DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Optional: set a full chat completions URL instead of DEEPSEEK_BASE_URL.
# DEEPSEEK_ENDPOINT=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-v4-flash
# Optional override. By default thinking is disabled for v4-pro and omitted for flash models.
# DEEPSEEK_DISABLE_THINKING=true
DEEPSEEK_TIMEOUT_MS=120000
# Optional retry count for transient API errors. Maximum is 5.
DEEPSEEK_MAX_RETRIES=2

# Required on Vercel when using Cloudflare D1 over the HTTP API.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=
# Optional local override: sqlite or d1. Vercel defaults to d1.
# QUIZFORGE_DB_DRIVER=sqlite

PORT=3000
